					Position = UDim2.new(0, -5, 0, -3),
					ZIndex = 1
				})
			})

			local Hit = Create("TextButton", {Text = "", BackgroundTransparency = 1, Size = UDim2.fromScale(1, 1), ZIndex = 5, Parent = TglBg})

			local function updateView(val, isInteracting)
				local trackColor = val and Colors.Accent or Color3.fromRGB(45, 45, 55)
				local knobPos = val and UDim2.fromOffset(isInteracting and 18 or 22, 2) or UDim2.fromOffset(2, 2)
				local knobSize = isInteracting and UDim2.fromOffset(24, 20) or UDim2.fromOffset(20, 20)
				local stateTextColor = val and Colors.Accent or Colors.TextSub

				TweenService:Create(Knob, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
					Position = knobPos,
					Size = knobSize
				}):Play()

				TweenService:Create(Track, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					BackgroundColor3 = trackColor
				}):Play()

				TweenService:Create(TrackGlow, TweenInfo.new(0.3), {
					ImageTransparency = val and 0.4 or 1
				}):Play()

				StateLabel.Text = val and "ON" or "OFF"
				TweenService:Create(StateLabel, TweenInfo.new(0.2), {
					TextColor3 = stateTextColor
				}):Play()
			end

			Hit.MouseEnter:Connect(function()
				Tween(TglBg, {BackgroundColor3 = Colors.ElementHover}, 0.2)
				Tween(TglBg.Stroke, {Color = Colors.Accent}, 0.2)
			end)

			Hit.MouseLeave:Connect(function()
				Tween(TglBg, {BackgroundColor3 = Colors.Element}, 0.2)
				Tween(TglBg.Stroke, {Color = Colors.Stroke}, 0.2)
				updateView(state, false) 
			end)

			Hit.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					updateView(state, true) 
					
					if UIS.TouchEnabled and HapticService:IsMotorSupported(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small) then
						HapticService:SetMotor(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small, 0.5)
						task.delay(0.05, function() HapticService:SetMotor(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small, 0) end)
					end
				end
			end)

			Hit.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					state = not state
					updateView(state, false)
					
					task.spawn(function()
						pcall(callback, state)
					end)
				end
			end)

			local ToggleAPI = {}
			
			function ToggleAPI:SetValue(val)
				if type(val) == "boolean" and state ~= val then
					state = val
					updateView(state, false)
					task.spawn(function() pcall(callback, state) end)
				end
			end

			function ToggleAPI:GetValue()
				return state
			end
			
			function ToggleAPI:Toggle()
				self:SetValue(not state)
			end
			
			function ToggleAPI:Destroy()
				TglBg:Destroy()
			end

			return ToggleAPI
		end

function Tab:Slider(config)
