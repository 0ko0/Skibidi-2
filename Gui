			Header.MouseButton1Click:Connect(function()
				expanded = not expanded
				
				if expanded then
					
					for _, other in pairs(Page:GetChildren()) do
						if other:IsA("Frame") then other.ZIndex = 1 end
					end
					DropdownBg.ZIndex = 10
				end

				UpdateSize()
				TweenService:Create(Arrow, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Rotation = expanded and 180 or 0}):Play()
				TweenService:Create(DropdownBg.UIStroke, TweenInfo.new(0.4), {
					Color = expanded and Color3.fromRGB(80, 150, 255) or Color3.fromRGB(45, 45, 60)
				}):Play()
				if SearchBox and expanded then SearchBox.Text = "" end 
			end)

			if isSearchable then
				SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
					local searchText = string.lower(SearchBox.Text)
					for btn, name in pairs(ItemsCollection) do
						if searchText == "" or string.find(string.lower(name), searchText) then
							btn.Visible = true
						else
							btn.Visible = false
						end
					end
					UpdateSize()
				end)
			end

			ListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
				if expanded then UpdateSize() end
			end)

			local DropdownFunctions = {}
			
			function DropdownFunctions:Refresh(newList, keepSelection)
				if not keepSelection then
					selectedItems = {}
					UpdateValueText()
				end
				
				for btn, _ in pairs(ItemsCollection) do btn:Destroy() end
				ItemsCollection = {}
				
				list = newList
				for _, v in pairs(list) do AddOption(v) end
				UpdateSize()
			end

			function DropdownFunctions:Set(val)
				selectedItems = {}
				if type(val) == "table" and isMultiSelect then
					for _, v in pairs(val) do table.insert(selectedItems, v) end
				elseif type(val) == "string" then
					table.insert(selectedItems, val)
				end
				
				UpdateValueText()
				callback(isMultiSelect and selectedItems or selectedItems[1])
				
				for btnObj, name in pairs(ItemsCollection) do
					local isSel = table.find(selectedItems, name) ~= nil
					btnObj.BackgroundTransparency = isSel and 0.85 or 1
					btnObj.BackgroundColor3 = isSel and Color3.fromRGB(80, 150, 255) or Color3.fromRGB(25, 25, 35)
					if btnObj:FindFirstChildOfClass("UIStroke") then btnObj:FindFirstChildOfClass("UIStroke").Transparency = isSel and 0.2 or 1 end
					if btnObj:FindFirstChildOfClass("TextLabel") then btnObj:FindFirstChildOfClass("TextLabel").TextColor3 = isSel and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(150, 150, 170) end
					if btnObj:FindFirstChildOfClass("ImageLabel") then btnObj:FindFirstChildOfClass("ImageLabel").ImageTransparency = isSel and 0 or 1 end
				end
			end

			return DropdownFunctions
		end

