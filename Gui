	local function MakeDraggable(TopBar, Object)
		local dragging = false
		local dragInput, mousePos, framePos
		local lerpTarget = Object.Position

		TopBar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				mousePos = input.Position
				framePos = Object.Position
				
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						dragging = false
					end
				end)
			end
		end)

		TopBar.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
				dragInput = input
			end
		end)

		UIS.InputChanged:Connect(function(input)
			if input == dragInput and dragging then
				local delta = input.Position - mousePos
				
				lerpTarget = UDim2.new(
					framePos.X.Scale, framePos.X.Offset + delta.X, 
					framePos.Y.Scale, framePos.Y.Offset + delta.Y
				)
			end
		end)
		
		 
		RunService.RenderStepped:Connect(function(deltaTime)
			if Object.Visible then
				local currentPos = Object.Position
				local lerpSpeed = 15 * deltaTime 
				Object.Position = UDim2.new(
					currentPos.X.Scale, 
					currentPos.X.Offset + (lerpTarget.X.Offset - currentPos.X.Offset) * lerpSpeed,
					currentPos.Y.Scale, 
					currentPos.Y.Offset + (lerpTarget.Y.Offset - currentPos.Y.Offset) * lerpSpeed
				)
			end
		end)
	end


