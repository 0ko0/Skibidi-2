			})

			
			local pulseTween1, pulseTween2
			local function PlayPulse()
				pulseTween1 = TweenService:Create(BindDisplay.Glow, TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {ImageTransparency = 0.4})
				pulseTween2 = TweenService:Create(BindDisplay.UIStroke, TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {Color = Colors.Accent})
				pulseTween1:Play()
				pulseTween2:Play()
			end

			local function StopPulse()
				if pulseTween1 then pulseTween1:Cancel() end
				if pulseTween2 then pulseTween2:Cancel() end
				Tween(BindDisplay.Glow, {ImageTransparency = 1}, 0.3)
				Tween(BindDisplay.UIStroke, {Color = Colors.Stroke}, 0.3)
			end

			
			Hit.MouseEnter:Connect(function()
				if not listening then
					Tween(BindBg, {BackgroundColor3 = Colors.ElementHover}, 0.2)
					Tween(BindDisplay, {BackgroundColor3 = Color3.fromRGB(40, 40, 60)}, 0.2)
				end
			end)

			Hit.MouseLeave:Connect(function()
				if not listening then
					Tween(BindBg, {BackgroundColor3 = Colors.Element}, 0.2)
					Tween(BindDisplay, {BackgroundColor3 = Color3.fromRGB(30, 30, 45)}, 0.2)
				end
			end)

			
			Hit.MouseButton1Click:Connect(function()
				listening = true
				BindText.Text = ". . ."
				BindText.TextColor3 = Colors.Accent
				
				
				Tween(BindDisplay, {Size = UDim2.fromOffset(60, 24), Position = UDim2.new(1, -80, 0.5, -12)}, 0.1, Enum.EasingStyle.Back).Completed:Connect(function()
					Tween(BindDisplay, {Size = UDim2.fromOffset(70, 28), Position = UDim2.new(1, -85, 0.5, -14)}, 0.2, Enum.EasingStyle.Back)
				end)

				PlayPulse()
			end)

			
			UIS.InputBegan:Connect(function(input, gpe)
				if listening then
					local isValidKey = input.UserInputType == Enum.UserInputType.Keyboard
					local isValidMouse = input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.MouseButton3 or input.UserInputType == Enum.UserInputType.MouseButton4 or input.UserInputType == Enum.UserInputType.MouseButton5
					
					if isValidKey or isValidMouse then
						listening = false
						StopPulse()

						
						if input.KeyCode == Enum.KeyCode.Escape or input.KeyCode == Enum.KeyCode.Backspace then
							currentBind = nil
							BindText.Text = "None"
							BindText.TextColor3 = Color3.fromRGB(150, 150, 170)
						else
							currentBind = (input.UserInputType == Enum.UserInputType.Keyboard) and input.KeyCode or input.UserInputType
							BindText.Text = GetKeyName(currentBind)
							BindText.TextColor3 = Color3.fromRGB(200, 200, 225)
						end

						
						BindDisplay.BackgroundColor3 = Colors.Accent
						Tween(BindDisplay, {BackgroundColor3 = Color3.fromRGB(30, 30, 45)}, 0.5)
						onChange(currentBind)
					end
				elseif not gpe and currentBind then
					
					if input.KeyCode == currentBind or input.UserInputType == currentBind then
						Tween(BindDisplay.UIStroke, {Color = Colors.Accent}, 0.1)
						Tween(BindDisplay, {Size = UDim2.fromOffset(64, 26), Position = UDim2.new(1, -82, 0.5, -13)}, 0.1)
						callback(true) 
					end
				end
			end)

			
			UIS.InputEnded:Connect(function(input, gpe)
				if not listening and not gpe and currentBind then
					if input.KeyCode == currentBind or input.UserInputType == currentBind then
						Tween(BindDisplay.UIStroke, {Color = Colors.Stroke}, 0.3)
						Tween(BindDisplay, {Size = UDim2.fromOffset(70, 28), Position = UDim2.new(1, -85, 0.5, -14)}, 0.2, Enum.EasingStyle.Back)
						callback(false) 
					end
				end
			end)
		end

		function Tab:Textbox(config)
			local text = config.Name or config.Title or "Textbox"
			local placeholder = config.Placeholder or "Enter text here..."
			local default = config.Default or ""
			local numericOnly = config.Numeric or false
			local maxChars = config.MaxChars or 0 
			local clearOnFocus = config.ClearTextOnFocus == nil and false or config.ClearTextOnFocus
			local multiLine = config.MultiLine or false
			local realtime = config.Realtime or false
			local callback = config.Callback or function() end

			local HapticService = game:GetService("HapticService")
			local isMobile = UIS.TouchEnabled and not UIS.MouseEnabled

			
			local baseHeight = multiLine and 75 or 55
			
			local BoxBg = Create("Frame", {
				Size = UDim2.new(1, 0, 0, baseHeight),
				BackgroundColor3 = Colors.Element,
				ClipsDescendants = false,
				Parent = Page
			}, {
				Create("UICorner", {CornerRadius = UDim.new(0, 8)}),
				Create("UIStroke", {Name = "Stroke", Color = Colors.Stroke, Thickness = 1, Transparency = 0.2}),
			})

			
			local Glow = Create("ImageLabel", {
				Name = "FocusGlow",
				BackgroundTransparency = 1,
				Image = "rbxassetid://6015045957",
				ImageColor3 = Colors.AccentGlow,
				ImageTransparency = 1,
				SliceCenter = Rect.new(49, 49, 450, 450),
				ScaleType = Enum.ScaleType.Slice,
				Size = UDim2.new(1, 30, 1, 30),
				Position = UDim2.new(0, -15, 0, -15),
				ZIndex = 0,
				Parent = BoxBg
			})

			
			local Label = Create("TextLabel", {
				Text = text,
				Font = Enum.Font.GothamBold,
				TextSize = 13,
				TextColor3 = Colors.TextMain,
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(15, 8),
				Size = UDim2.new(1, -30, 0, 15), 
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 2,
				Parent = BoxBg
			})

			
			local InputHolder = Create("Frame", {
				Size = UDim2.new(1, -30, 1, -30),
				Position = UDim2.new(0, 15, 0, 25),
				BackgroundColor3 = Color3.fromRGB(15, 15, 22),
				ClipsDescendants = true,
				ZIndex = 2,
				Parent = BoxBg
			}, {
				Create("UICorner", {CornerRadius = UDim.new(0, 6)}),
				Create("UIStroke", {Name = "InnerStroke", Color = Color3.fromRGB(40, 40, 55), Thickness = 1})
			})

			
			local Underline = Create("Frame", {
				Size = UDim2.new(0, 0, 0, 2),
				Position = UDim2.new(0.5, 0, 1, -2),
				AnchorPoint = Vector2.new(0.5, 0),
				BackgroundColor3 = Colors.Accent,
				BorderSizePixel = 0,
				ZIndex = 3,
				Parent = InputHolder
			})

			
			local Input = Create("TextBox", {
				Text = default,
				PlaceholderText = placeholder,
				Font = Enum.Font.GothamMedium,
				TextSize = 12,
				TextColor3 = Color3.fromRGB(220, 220, 240),
				PlaceholderColor3 = Color3.fromRGB(100, 100, 120),
				BackgroundTransparency = 1,
				Size = UDim2.new(1, -65, 1, -4), 
				Position = UDim2.new(0, 10, 0, 2),
				TextXAlignment = Enum.TextXAlignment.Left,
				TextYAlignment = multiLine and Enum.TextYAlignment.Top or Enum.TextYAlignment.Center,
				TextWrapped = multiLine,
				ClearTextOnFocus = clearOnFocus,
				MultiLine = multiLine,
				ZIndex = 3,
				Parent = InputHolder
			})

			
			local CharCounter = Create("TextLabel", {
				Text = maxChars > 0 and string.format("%d/%d", #default, maxChars) or "",
				Font = Enum.Font.GothamMedium,
				TextSize = 10,
				TextColor3 = Colors.TextSub,
				BackgroundTransparency = 1,
				Position = UDim2.new(1, -15, 0, 8),
				Size = UDim2.new(0, 100, 0, 15),
				TextXAlignment = Enum.TextXAlignment.Right,
				AnchorPoint = Vector2.new(1, 0),
				TextTransparency = maxChars > 0 and 0.3 or 1,
				ZIndex = 2,
				Parent = BoxBg
			})

			
			local UtilsContainer = Create("Frame", {
				Size = UDim2.new(0, 50, 1, 0),
				Position = UDim2.new(1, -50, 0, 0),
				BackgroundTransparency = 1,
				ZIndex = 4,
				Parent = InputHolder
			}, {
				Create("UIListLayout", {
					FillDirection = Enum.FillDirection.Horizontal,
					HorizontalAlignment = Enum.HorizontalAlignment.Right,
					VerticalAlignment = Enum.VerticalAlignment.Center,
					Padding = UDim.new(0, 5)
				}),
				Create("UIPadding", {PaddingRight = UDim.new(0, 5)})
			})

			
			local ClearBtn = Create("ImageButton", {
				Size = UDim2.fromOffset(18, 18),
				BackgroundTransparency = 1,
				Image = "rbxassetid://10137563140", -- Icon X
				ImageColor3 = Color3.fromRGB(255, 80, 80),
				ImageTransparency = 1, 
				AutoButtonColor = false,
				Parent = UtilsContainer
			})

			local CopyBtn = Create("ImageButton", {
				Size = UDim2.fromOffset(16, 16),
				BackgroundTransparency = 1,
				Image = "rbxassetid://10827798319", -- Icon Copy
				ImageColor3 = Colors.Accent,
				ImageTransparency = 1, 
				AutoButtonColor = false,
				Parent = UtilsContainer
			})

			
			local function UpdateUtilsVisibility()
				local hasText = #Input.Text > 0
				TweenService:Create(ClearBtn, TweenInfo.new(0.2), {ImageTransparency = hasText and 0.3 or 1}):Play()
				TweenService:Create(CopyBtn, TweenInfo.new(0.2), {ImageTransparency = hasText and 0.3 or 1}):Play()
				
				if maxChars > 0 then
					CharCounter.Text = string.format("%d/%d", #Input.Text, maxChars)
					if #Input.Text >= maxChars then
						TweenService:Create(CharCounter, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(255, 80, 80)}):Play()
					else
						TweenService:Create(CharCounter, TweenInfo.new(0.2), {TextColor3 = Colors.TextSub}):Play()
					end
				end
			end

			ClearBtn.MouseButton1Click:Connect(function()
				Input.Text = ""
				UpdateUtilsVisibility()
				Input:CaptureFocus()
			end)
			ClearBtn.MouseEnter:Connect(function() if #Input.Text>0 then Tween(ClearBtn, {ImageTransparency = 0, Size = UDim2.fromOffset(20, 20)}, 0.1) end end)
			ClearBtn.MouseLeave:Connect(function() Tween(ClearBtn, {ImageTransparency = 0.3, Size = UDim2.fromOffset(18, 18)}, 0.2) end)

			CopyBtn.MouseButton1Click:Connect(function()
				if #Input.Text > 0 and setclipboard then
					setclipboard(Input.Text)
					CopyBtn.Image = "rbxassetid://10827797825" -- Icon Tích xanh
					Tween(CopyBtn, {ImageColor3 = Color3.fromRGB(80, 255, 80)}, 0.1)
					task.wait(1)
					CopyBtn.Image = "rbxassetid://10827798319"
					Tween(CopyBtn, {ImageColor3 = Colors.Accent}, 0.3)
				end
			end)
			CopyBtn.MouseEnter:Connect(function() if #Input.Text>0 then Tween(CopyBtn, {ImageTransparency = 0, Size = UDim2.fromOffset(18, 18)}, 0.1) end end)
			CopyBtn.MouseLeave:Connect(function() Tween(CopyBtn, {ImageTransparency = 0.3, Size = UDim2.fromOffset(16, 16)}, 0.2) end)

			
			Input:GetPropertyChangedSignal("Text"):Connect(function()
				local t = Input.Text

				
				if numericOnly then
					t = string.gsub(t, "%D", "")
					if Input.Text ~= t then Input.Text = t end
				end

				
				if maxChars > 0 and #t > maxChars then
					Input.Text = string.sub(t, 1, maxChars)
					
					if isMobile and HapticService:IsMotorSupported(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small) then
						HapticService:SetMotor(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small, 0.8)
						task.delay(0.1, function() HapticService:SetMotor(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small, 0) end)
					end
				end

				UpdateUtilsVisibility()

				if realtime then
					task.spawn(callback, Input.Text)
				end
			end)

			
			Input.Focused:Connect(function()
				if isMobile and HapticService:IsMotorSupported(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small) then
					HapticService:SetMotor(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small, 0.3)
					task.delay(0.05, function() HapticService:SetMotor(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small, 0) end)
				end

				
				TweenService:Create(BoxBg.Stroke, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Color = Colors.Accent, Transparency = 0}):Play()
				TweenService:Create(InputHolder.InnerStroke, TweenInfo.new(0.4), {Color = Colors.Accent}):Play()
				TweenService:Create(Glow, TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {ImageTransparency = 0.5}):Play()
				TweenService:Create(Label, TweenInfo.new(0.3), {TextColor3 = Colors.Accent}):Play()
				
				
				TweenService:Create(Underline, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, 2)}):Play()
				
				UpdateUtilsVisibility()
			end)

			Input.FocusLost:Connect(function(enterPressed)
				
				TweenService:Create(BoxBg.Stroke, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Color = Colors.Stroke, Transparency = 0.2}):Play()
				TweenService:Create(InputHolder.InnerStroke, TweenInfo.new(0.4), {Color = Color3.fromRGB(40, 40, 55)}):Play()
				TweenService:Create(Glow, TweenInfo.new(0.4), {ImageTransparency = 1}):Play()
				TweenService:Create(Label, TweenInfo.new(0.3), {TextColor3 = Colors.TextMain}):Play()
				
				
				TweenService:Create(Underline, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = UDim2.new(0, 0, 0, 2)}):Play()
				
				TweenService:Create(ClearBtn, TweenInfo.new(0.3), {ImageTransparency = 1}):Play()
				TweenService:Create(CopyBtn, TweenInfo.new(0.3), {ImageTransparency = 1}):Play()

				
				if not realtime then
					task.spawn(callback, Input.Text, enterPressed)
				end
			end)

			
			UpdateUtilsVisibility()
			TweenService:Create(ClearBtn, TweenInfo.new(0), {ImageTransparency = 1}):Play()
			TweenService:Create(CopyBtn, TweenInfo.new(0), {ImageTransparency = 1}):Play()

			
			local TextboxAPI = {}
			
			function TextboxAPI:Set(newText)
				Input.Text = tostring(newText)
				if not realtime then task.spawn(callback, Input.Text, false) end
			end

			function TextboxAPI:Get()
				return Input.Text
			end
			
			function TextboxAPI:Clear()
				Input.Text = ""
				if not realtime then task.spawn(callback, "", false) end
			end

			function TextboxAPI:Focus()
				Input:CaptureFocus()
			end

			return TextboxAPI
		end

return Tab
	end

	return self
end

return Library
