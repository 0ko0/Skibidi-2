			TweenService:Create(ContentHolder, TweenInfo.new(0.15, Enum.EasingStyle.Sine), {Size = UDim2.fromScale(0.95, 0.95), Position = UDim2.fromScale(0.025, 0.025)}):Play()
		end)

		TabBg.MouseButton1Click:Connect(function()
			
			if isMobile and HapticService:IsMotorSupported(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small) then
				HapticService:SetMotor(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small, 0.6)
				task.delay(0.05, function() HapticService:SetMotor(Enum.UserInputType.Gamepad1, Enum.VibrationMotor.Small, 0) end)
			end

			CreateRipple(UIS:GetMouseLocation().X, UIS:GetMouseLocation().Y)
			TweenService:Create(ContentHolder, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.fromScale(1, 1), Position = UDim2.fromScale(0, 0)}):Play()

			
			if self.TabHighlight then
				self.TabHighlight.Visible = true
				TweenService:Create(self.TabHighlight, TweenInfo.new(0.4, Enum.EasingStyle.Spring, Enum.EasingDirection.Out), {
					Position = UDim2.fromOffset(8, TabBg.AbsolutePosition.Y - self.Sidebar.AbsolutePosition.Y),
					BackgroundColor3 = tabColor
				}):Play()
				self.TabHighlight.UIStroke.Color = tabColor
			end

			
			for _, bg in pairs(self.TabHolder:GetChildren()) do
				if bg:IsA("TextButton") and bg ~= TabBg then
					TweenService:Create(bg, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
					TweenService:Create(bg.UIStroke, TweenInfo.new(0.3), {Transparency = 1}):Play()
					
					local icon = bg:FindFirstChild("Icon", true)
					local title = bg:FindFirstChild("Title", true)
					if icon then TweenService:Create(icon, TweenInfo.new(0.3), {ImageColor3 = Color3.fromRGB(150, 150, 170)}):Play() end
					if title then
						TweenService:Create(title, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(150, 150, 170)}):Play()
						title.Font = Enum.Font.GothamMedium
					end
				end
			end

			
			TweenService:Create(TabBg, TweenInfo.new(0.3), {BackgroundTransparency = 0.8}):Play()
			TweenService:Create(TabBg.UIStroke, TweenInfo.new(0.3), {Transparency = 0.5}):Play()
			if hasIcon then TweenService:Create(ContentHolder.Icon, TweenInfo.new(0.3), {ImageColor3 = tabColor}):Play() end
			TweenService:Create(TabText, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
			TabText.Font = Enum.Font.GothamBold

			
			for _, p in pairs(self.Pages:GetChildren()) do
				if p:IsA("ScrollingFrame") and p ~= Page then
				
					TweenService:Create(p, TweenInfo.new(0.3, Enum.EasingStyle.Sine, Enum.EasingDirection.In), {
						Position = UDim2.fromScale(-0.05, 0),
						ScrollBarImageTransparency = 1
					}):Play()
					task.delay(0.3, function() if p.Position.X.Scale == -0.05 then p.Visible = false end end)
				end
			end

			Page.Visible = true
			Page.Position = UDim2.fromScale(0.05, 0) 
			TweenService:Create(Page, TweenInfo.new(0.45, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
				Position = UDim2.fromScale(0, 0),
				ScrollBarImageTransparency = 0
			}):Play()
		end)

		local count = 0
		for _, child in pairs(self.TabHolder:GetChildren()) do if child:IsA("TextButton") then count = count + 1 end end
		if count == 1 then
			task.spawn(function()
				TabBg.BackgroundTransparency = 0.8
				TabBg.UIStroke.Transparency = 0.5
				if hasIcon then ContentHolder.Icon.ImageColor3 = tabColor end
				TabText.TextColor3 = Color3.fromRGB(255, 255, 255)
				TabText.Font = Enum.Font.GothamBold
				Page.Visible = true
				Page.Position = UDim2.fromScale(0, 0)
				Page.ScrollBarImageTransparency = 0
				
				task.wait(0.1) 
				if self.TabHighlight then
					self.TabHighlight.Visible = true
					self.TabHighlight.Position = UDim2.fromOffset(8, TabBg.AbsolutePosition.Y - self.Sidebar.AbsolutePosition.Y)
					self.TabHighlight.BackgroundColor3 = tabColor
					self.TabHighlight.UIStroke.Color = tabColor
				end
			end)
		end
		
