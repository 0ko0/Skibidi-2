			local currentBind = default
			local listening = false

			
			local function GetKeyName(bind)
				if not bind then return "None" end
				local name = bind.Name
				local shortNames = {
					LeftControl = "LCtrl", RightControl = "RCtrl", LeftShift = "LShift", RightShift = "RShift",
					LeftAlt = "LAlt", RightAlt = "RAlt", Escape = "Esc", Return = "Enter", Backspace = "Back",
					PageUp = "PgUp", PageDown = "PgDn", Insert = "Ins", Delete = "Del", Home = "Home", End = "End",
					MouseButton1 = "MB1", MouseButton2 = "MB2", MouseButton3 = "MB3", MouseButton4 = "MB4", MouseButton5 = "MB5"
				}
				return shortNames[name] or name
			end

			
