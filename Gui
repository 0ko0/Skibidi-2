						TweenService:Create(Arrow, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Rotation = 0}):Play()
						TweenService:Create(DropdownBg.UIStroke, TweenInfo.new(0.4), {Color = Color3.fromRGB(45, 45, 60)}):Play()
						
						
						for btnObj, name in pairs(ItemsCollection) do
							local tLbl = btnObj:FindFirstChildOfClass("TextLabel")
							local tIco = btnObj:FindFirstChildOfClass("ImageLabel")
							local tStr = btnObj:FindFirstChildOfClass("UIStroke")
							if name == itemName then
								TweenService:Create(btnObj, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(80, 150, 255), BackgroundTransparency = 0.85}):Play()
								if tStr then TweenService:Create(tStr, TweenInfo.new(0.3), {Transparency = 0.2, Color = Color3.fromRGB(80, 150, 255)}):Play() end
								if tLbl then TweenService:Create(tLbl, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play() end
								if tIco then TweenService:Create(tIco, TweenInfo.new(0.3), {ImageTransparency = 0}):Play() end
							else
								TweenService:Create(btnObj, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(25, 25, 35), BackgroundTransparency = 1}):Play()
								if tStr then TweenService:Create(tStr, TweenInfo.new(0.3), {Transparency = 1}):Play() end
								if tLbl then TweenService:Create(tLbl, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(150, 150, 170)}):Play() end
								if tIco then TweenService:Create(tIco, TweenInfo.new(0.3), {ImageTransparency = 1}):Play() end
							end
						end
					end
				end)
			end

			
