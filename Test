local Theme = {
	Black = Color3.fromRGB(0, 0, 0),
	DarkGray = Color3.fromRGB(10, 10, 10),
	LightGray = Color3.fromRGB(20, 20, 20),
	Blue = Color3.fromRGB(110, 150, 255),
	TextWhite = Color3.fromRGB(255, 255, 255),
	TextMuted = Color3.fromRGB(150, 150, 150)
}

local function Create(class, props, children)
	local obj = Instance.new(class)
	for k, v in pairs(props or {}) do obj[k] = v end
	for _, c in pairs(children or {}) do c.Parent = obj end
	return obj
end

-- Hiệu ứng Tween mượt mà
local function Tween(obj, props, time)
	local tw = TweenService:Create(obj, TweenInfo.new(time or 0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), props)
	tw:Play()
	return tw
end

local Library = {}
Library.__index = Library
Library.ToggleKey = Enum.KeyCode.RightControl

function Library.SettingManager()
	local Manager = {}
	function Manager:AddToTab(tab)
		tab:Paragraph({ Title = "SYSTEM SETTINGS", Content = "Manage your VIP Interface here." })
		tab:Keybind({
			Name = "Toggle UI Key",
			Default = Library.ToggleKey,
			OnChange = function(New) Library.ToggleKey = New end
		})
		tab:Button({
			Name = "Unload Interface",
			Callback = function()
				local gui = gethui and gethui():FindFirstChild("VuzxVIP") or CoreGui:FindFirstChild("VuzxVIP")
				if gui then gui:Destroy() end
			end
		})
	end
	return Manager
end

