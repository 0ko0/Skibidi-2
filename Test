		function Tab:Slider(config)
			local min, max, default = config.Min or 0, config.Max or 100, config.Default or 0
			local value = default
			local SliderBg = Create("Frame", { Size = UDim2.new(1, 0, 0, 55), BackgroundColor3 = Theme.LightGray, Parent = Page }, {
				Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
				Create("TextLabel", { Text = config.Name, Font = Enum.Font.GothamMedium, TextSize = 13, TextColor3 = Theme.TextWhite, BackgroundTransparency = 1, Position = UDim2.fromOffset(15, 5), Size = UDim2.new(1, -30, 0, 20), TextXAlignment = "Left" }),
			})

			local ValText = Create("TextLabel", { Text = tostring(default), Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = Theme.Blue, BackgroundTransparency = 1, Position = UDim2.new(1, -65, 0, 5), Size = UDim2.fromOffset(50, 20), TextXAlignment = "Right", Parent = SliderBg })

			local Tray = Create("TextButton", { Size = UDim2.new(1, -30, 0, 6), Position = UDim2.new(0, 15, 1, -15), BackgroundColor3 = Theme.DarkGray, Text = "", Parent = SliderBg }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })
			local Fill = Create("Frame", { Size = UDim2.fromScale((default - min)/(max - min), 1), BackgroundColor3 = Theme.Blue, Parent = Tray }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })
			local Knob = Create("Frame", { Size = UDim2.fromOffset(14, 14), AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new((default - min)/(max - min), 0, 0.5, 0), BackgroundColor3 = Theme.TextWhite, Parent = Tray }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }), Create("UIStroke",{Color=Theme.Blue, Thickness=2}) })

			local dragging = false
			local function UpdateSlider(input)
				local perc = math.clamp((input.Position.X - Tray.AbsolutePosition.X) / Tray.AbsoluteSize.X, 0, 1)
				value = math.floor(min + ((max - min) * perc))
				ValText.Text = tostring(value)
				Tween(Fill, {Size = UDim2.fromScale(perc, 1)}, 0.1)
				Tween(Knob, {Position = UDim2.new(perc, 0, 0.5, 0)}, 0.1)
				if config.Callback then config.Callback(value) end
			end

			Tray.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true; UpdateSlider(input) end end)
			UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
			UIS.InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then UpdateSlider(input) end end)
		end

