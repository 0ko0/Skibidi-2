			dragging = true; dragStart = input.Position; startPos = self.Main.Position
			input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
		end
	end)
	UIS.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			self.Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)

	-- Logic Ẩn/Hiện UI
	local function ToggleUI()
		self.Open = not self.Open
		if self.Open then
			self.Main.Visible = true
			Tween(self.Main, {Size = workspace.CurrentCamera.ViewportSize.X > 700 and UDim2.fromOffset(600, 420) or UDim2.new(0.9, 0, 0.85, 0), BackgroundTransparency = 0})
			for _, v in pairs(self.Main:GetDescendants()) do
				if v:IsA("TextLabel") or v:IsA("TextButton") then Tween(v, {TextTransparency = 0}) end
				if v:IsA("UIStroke") then Tween(v, {Transparency = 0.2}) end
			end
		else
			local t = Tween(self.Main, {Size = UDim2.fromOffset(0, 0), BackgroundTransparency = 1})
			for _, v in pairs(self.Main:GetDescendants()) do
				if v:IsA("TextLabel") or v:IsA("TextButton") then Tween(v, {TextTransparency = 1}) end
				if v:IsA("UIStroke") then Tween(v, {Transparency = 1}) end
			end
			t.Completed:Connect(function() if not self.Open then self.Main.Visible = false end end)
		end
	end

	UIS.InputBegan:Connect(function(input, gpe)
		if not gpe and input.KeyCode == Library.ToggleKey then ToggleUI() end
	end)
	FloatingToggle.MouseButton1Click:Connect(ToggleUI)
	
	-- Drag Floating Button
	local f_dragging, f_dragStart, f_startPos
	FloatingToggle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			f_dragging = true; f_dragStart = input.Position; f_startPos = FloatingToggle.Position
			input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then f_dragging = false end end)
		end
	end)
	UIS.InputChanged:Connect(function(input)
		if f_dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - f_dragStart
			FloatingToggle.Position = UDim2.new(0, f_startPos.X.Offset + delta.X, 0, f_startPos.Y.Offset + delta.Y)
		end
	end)

